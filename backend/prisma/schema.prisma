generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  HR
  EMPLOYEE
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model Employee {
  id                String         @id @default(uuid())
  firstName         String
  lastName          String
  email             String         @unique
  passwordHash      String
  role              Role
  department        String
  position          String?
  leaveBalance      Int            @default(20)
  isActive          Boolean        @default(true)
  deletedAt         DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  leaves            LeaveRequest[]
  refreshTokens     RefreshToken[]

  @@index([deletedAt])
  @@index([department])
  @@index([role])
}

model LeaveRequest {
  id          String      @id @default(uuid())
  employeeId  String
  employee    Employee    @relation(fields: [employeeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  reviewNote  String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([employeeId, status])
  @@index([startDate, endDate])
}

model RefreshToken {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  tokenHash   String
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([employeeId])
  @@index([revokedAt, expiresAt])
}

model ActivityLog {
  id               String   @id @default(uuid())
  action           String
  entityType       String
  entityId         String
  message          String
  actorId          String?
  targetEmployeeId String?
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([targetEmployeeId])
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String
  href        String
  tone        String    @default("info")
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}
